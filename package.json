{
  "name": "v5waitme",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "tunnel:dev": "node scripts/tunnel-dev.mjs",
    "tunnel": "ngrok http 5173",
    "start": "vite",
    "dev:clean": "rm -rf node_modules/.vite && vite",
    "build": "vite build",
    "build:check": "node scripts/build-check.mjs",
    "prepare": "node scripts/ensure-git-hooks.mjs",
    "test": "node --test \"test/*.test.js\"",
    "test:ui": "vitest run",
    "test:e2e": "playwright test",
    "e2e": "playwright test",
    "lint": "eslint . --max-warnings 0 && tsc --noEmit",
    "format": "prettier --write .",
    "quality": "node scripts/quality-gate.mjs",
    "state:app": "node scripts/generate-state-of-app.mjs",
    "clean": "node scripts/auto-clean.mjs",
    "knip": "knip --include files,dependencies,unlisted --no-config-hints",
    "supabase:setup": "node scripts/supabase-setup.mjs",
    "supabase:types": "supabase gen types typescript --linked",
    "cap:sync": "npm run build && npx cap sync ios",
    "cap:open:ios": "npx cap open ios"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "waitme-web-auth": "file:./packages/waitme-web-auth",
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@sentry/react": "^10.47.0",
    "@supabase/supabase-js": "^2.100.0",
    "mapbox-gl": "^3.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.26.0",
    "@babel/preset-react": "^7.26.0",
    "@capacitor/cli": "^8.3.0",
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.51.0",
    "@sentry/vite-plugin": "^5.1.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^9.18.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^29.0.0",
    "knip": "^6.3.0",
    "prettier": "^3.4.2",
    "supabase": "^2.84.4",
    "typescript": "^5.8.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.1"
  }
}
