# VITE_SUPABASE_URL = URL real del proyecto (https://<ref>.supabase.co), no placeholders.
# Mismo origen dev para Safari + OAuth web + coherencia con iPhone (Capacitor live reload). Ej: http://192.168.0.50:5173
# `npm run dev:ios` crea/actualiza esta línea en .env.local automáticamente. Si se omite y solo usas dev:vite, Vite infiere la IP.
VITE_DEV_LAN_ORIGIN=
# Auth (Google) — Supabase → Authentication → URL Configuration → Redirect URLs. Lista completa (las cuatro):
#   1) capacitor://localhost
#   2) http://<IP_LAN>:5173  (misma que OPEN IN SAFARI / dev:ios; no localhost para iPhone)
#   3) https://<URL_EXACTA_STAGING>  (copiar del Vercel → Deployments → rama staging → Visit; ver docs/STAGING_VERCEL.md)
#   4) https://<DOMINIO_PRODUCTION_VERCEL>
# Staging no se commitea aquí: la URL la da Vercel tras el primer push a la rama "staging".
# No commitees WAITME_CAP_DEV_SERVER_URL (solo al ejecutar npm run dev:ios / cap:live:on).
VITE_MAPBOX_ACCESS_TOKEN=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
